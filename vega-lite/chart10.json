  "encoding": {
    "x": {
      "field": "month",
      "type": "ordinal",
      "sort": ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"],
      "title": null,
      "scale": { "padding": 0.18 },
      "axis": {
        "labelFont": "Archivo",
        "labelFontSize": 11,
        "labelColor": "#5A5550",
        "labelAngle": 0,
        "domainColor": "#D8D2C8",
        "ticks": false,
        "labelPadding": 10
      }
    },
    "y": {
      "field": "cases",
      "type": "quantitative",
      "title": "Average cases per week",
      "scale": { "domain": [0, 2600] },
      "axis": {
        "format": "~s",
        "tickCount": 4,
        "titleFont": "Archivo",
        "titleFontSize": 10,
        "titleColor": "#8C827A",
        "titleFontWeight": 600,
        "labelFont": "Archivo",
        "labelFontSize": 10,
        "labelColor": "#8C827A",
        "grid": true,
        "gridColor": "#F0ECE4",
        "domain": false,
        "ticks": false,
        "titlePadding": 12,
        "labelPadding": 8
      }
    },
    "color": {
      "field": "era",
      "type": "nominal",
      "scale": {
        "domain": ["Pre-COVID", "COVID", "Post-COVID"],
        "range": ["#B7AEA1", "#E69F00", "#B5121B"]
      },
      "legend": null
    }
  },
  "layer": [
    {
      "description": "Base Trend Lines Layer",
      "mark": { "type": "line", "strokeWidth": 3, "interpolate": "monotone" }
    },
    {
      "description": "Interactive Data Points Layer",
      "mark": { "type": "point", "filled": true, "size": 42, "opacity": 0.9, "stroke": "#FFFFFF", "strokeWidth": 1 },
      "encoding": {
        "tooltip": [
          { "field": "fullLabel", "title": "Period" },
          { "field": "month", "title": "Month" },
          { "field": "cases", "title": "Avg cases/week", "format": "," }
        ]
      }
    },
    {
      "description": "Right Edge Series Tags Layer",
      "transform": [ { "filter": "datum.month=='Dec'" } ],
      "mark": { "type": "text", "align": "left", "dx": 9, "baseline": "middle", "font": "Archivo", "fontSize": 11.5, "fontWeight": 700 },
      "encoding": { "text": { "field": "endLabel" } }
    },
    {
      "description": "Corrected Clean Multi-line Charcoal Black Valley Annotation Layer",
      "data": {
        "values": [
          { "month": "Aug", "cases": 1067 }
        ]
      },
      "mark": {
        "type": "text",
        "align": "center",
        "baseline": "middle",
        "font": "Archivo",
        "fontSize": 10.5,
        "fontWeight": 600,
        "lineHeight": 13,
        "color": "#1C1714",
        "dy": 75
      },
      "encoding": {
        "x": { "field": "month", "type": "ordinal" },
        "y": { "field": "cases", "type": "quantitative" },
        "text": {
          "value": [
            "Lockdowns and limited mobility crushed",
            "transmission late in the year."
          ]
        },
        "color": null
      }
    },
    {
      "description": "Post-COVID Peak Shift Highlight Layer",
      "data": {
        "values": [
          { "month": "Nov", "cases": 2150, "t": "2022 peak shifts to December" }
        ]
      },
      "mark": { "type": "text", "align": "right", "dx": -2, "font": "Archivo", "fontSize": 11, "fontWeight": 700, "color": "#B5121B" },
      "encoding": {
        "x": {
          "field": "month",
          "type": "ordinal",
          "sort": ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"]
        },
        "y": { "field": "cases", "type": "quantitative" },
        "text": { "field": "t" }
      }
    }
  ],
  "config": {
    "view": { "stroke": null },
    "font": "Archivo",
    "padding": { "right": 74 }
  }
